# Obsidian
thought() { obsidian "daily:append" "content=- $1"; }
dump() { obsidian "daily:append" "heading=Dump" "content=- $1"; }
todo() { obsidian "daily:append" "heading=Todo" "content=- [ ] $1"; }

# Shared commit message prompt for AI-generated messages
_COMMIT_MSG_PROMPT="Write a commit message in the Conventional Commits format. Use the structure:
    <type>(<optional scope>): <short description>

    <optional body>

    <optional footer>

Example types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
Optionally, include a body for more details in bullet points.
Optionally, in the footer, use BREAKING CHANGE: followed by a detailed explanation of the breaking change.

Just return the commit message as plain text. Do not wrap it in backticks or any other formatting."

# Generate commit message from staged diff
_generate_commit_msg() {
  git diff --cached | pi -p --provider github-copilot --model claude-haiku-4.5 "$_COMMIT_MSG_PROMPT" | sed 's/`//g'
}

# Stage and generate commit message from diff
commit() {
  if [[ ! -d .git ]]; then
    printf '\033[33m=> Initializing git repository...\033[0m\n'
    git init
  fi

  local diff=$(git diff --cached --stat)
  if [[ -z "$diff" ]]; then
    printf '\033[33m=> No changes to commit.\033[0m\n'
    return 0
  fi

  printf '\033[36m%s\033[0m\n' "$diff"
  printf '\n\033[34m=> Generating commit message...\033[0m\n'
  local msg=$(_generate_commit_msg)

  printf '\n\033[1m--- Proposed commit message ---\033[0m\n'
  printf '\033[32m%s\033[0m\n' "$msg"
  printf '\033[1m-------------------------------\033[0m\n\n'
  read "confirm?Commit with this message? [y/N] "
  if [[ "$confirm" =~ ^[Yy]$ ]]; then
    git commit -m "$msg"
    printf '\033[32m=> Committed successfully.\033[0m\n'
  else
    printf '\033[31m=> Commit aborted. Changes remain staged.\033[0m\n'
  fi
}

# Auto stage, generate commit message, and push
acp() {
  if [[ ! -d .git ]]; then
    printf '\033[33m=> Initializing git repository...\033[0m\n'
    git init
  fi

  printf '\033[34m=> Staging all files...\033[0m\n'
  git add -A

  local diff=$(git diff --cached --stat)
  if [[ -z "$diff" ]]; then
    printf '\033[33m=> No changes to commit.\033[0m\n'
    return 0
  fi

  printf '\033[36m%s\033[0m\n' "$diff"
  printf '\n\033[34m=> Generating commit message...\033[0m\n'
  local msg=$(_generate_commit_msg)

  printf '\n\033[1m--- Proposed commit message ---\033[0m\n'
  printf '\033[32m%s\033[0m\n' "$msg"
  printf '\033[1m-------------------------------\033[0m\n\n'
  git commit -m "$msg"
  printf '\033[34m=> Pushing to remote...\033[0m\n'
  git push
  printf '\033[32m=> Done.\033[0m\n'
}

# Git Worktrees
gwab() {
  git worktree add -b "$1" "../$(basename $(pwd))-$1"
}

gwae() {
  git worktree add "../$(basename $(pwd))-$1" "$1"
}

gwao() {
  local worktree_path="../$(basename $(pwd))-$1"
  git worktree add --track -b "$1" "$worktree_path" "origin/$1"
  if [[ -f "$worktree_path/package.json" ]]; then
    echo "Installing dependencies..."
    (cd "$worktree_path" && npm install)
  fi
  cd "$worktree_path"
}

gwcd() {
  local wt=$(git worktree list | grep -i "$1" | head -1 | awk '{print $1}')
  [[ -n "$wt" ]] && cd "$wt" || echo "No worktree matching '$1'"
}

# Dump a file to ~/Workspaces/leovanhaaren/dump and push
dumpf() {
  local dump_dir="$HOME/Workspaces/leovanhaaren/dump"

  if [[ -z "$1" || ! -f "$1" ]]; then
    printf '\033[31m=> Usage: dumpf <file>\033[0m\n'
    return 1
  fi

  local src="$1"
  local basename="${src:t}"

  read "filename?Filename (leave blank for '${basename}'): "
  [[ -z "$filename" ]] && filename="$basename"

  local filepath="$dump_dir/$filename"
  if [[ -f "$filepath" ]]; then
    printf '\033[33m=> File already exists: %s\033[0m\n' "$filepath"
    read "overwrite?Overwrite? [y/N] "
    if [[ ! "$overwrite" =~ ^[Yy]$ ]]; then
      printf '\033[31m=> Aborted.\033[0m\n'
      return 1
    fi
  fi

  cp "$src" "$filepath"
  printf '\033[32m=> Copied to %s\033[0m\n' "$filepath"

  git -C "$dump_dir" add "$filepath"

  local diff=$(git -C "$dump_dir" diff --cached --stat)
  if [[ -z "$diff" ]]; then
    printf '\033[33m=> No changes to commit.\033[0m\n'
    return 0
  fi

  local msg=$(git -C "$dump_dir" diff --cached | pi -p --provider github-copilot --model claude-haiku-4.5 "$_COMMIT_MSG_PROMPT" | sed 's/`//g')

  printf '\n\033[1m--- Proposed commit message ---\033[0m\n'
  printf '\033[32m%s\033[0m\n' "$msg"
  printf '\033[1m-------------------------------\033[0m\n\n'
  read "confirm?Commit and push with this message? [y/N] "
  if [[ "$confirm" =~ ^[Yy]$ ]]; then
    git -C "$dump_dir" commit -m "$msg"
    git -C "$dump_dir" push
    printf '\033[32m=> Committed and pushed successfully.\033[0m\n'
  else
    printf '\033[31m=> Commit aborted. Changes remain staged.\033[0m\n'
  fi
}

# Z.AI + Claude Code launcher
zai() {
  pass-cli inject --in-file "${DOTFILES_DIR}/ai-providers/zai.zsh" | while read -r line; do
    eval "$line"
  done

  claude "$@"
}

mm() {
  pass-cli inject --in-file "${DOTFILES_DIR}/ai-providers/minimax.zsh" | while read -r line; do
    eval "$line"
  done

  claude "$@"
}

session () {
  WORK_DIR="${1:-$PWD}"
  EXTENSION_DIR="~/Workspaces/clones/pi-vs-claude-code/extensions"
  EXTENSIONS="--extension $EXTENSION_DIR/coms.ts --extension $EXTENSION_DIR/minimal.ts"
  THINKING_MODEL="openai-codex/gpt-5.5:xhigh"
  PLANNING_MODEL="opencode-go/deepseek-v4-pro:xhigh"
  WORKER_MODEL="opencode-go/deepseek-v4-flash:xhigh"
  SESSION="$(basename "$WORK_DIR")-team"

  local NAMES=(truus sjaak henk greet kees mien bep dirk ria wim)
  local i j tmp
  for ((i = ${#NAMES[@]}; i > 1; i--)); do
    j=$((RANDOM % i + 1))
    tmp="${NAMES[i]}"
    NAMES[i]="${NAMES[j]}"
    NAMES[j]="$tmp"
  done

  tmux kill-session -t $SESSION
  tmux new-session -d -s $SESSION
  tmux split-window -h -t $SESSION:1.1
  tmux split-window -v -t $SESSION:1.2
  tmux split-window -v -t $SESSION:1.1
  tmux send-keys -t $SESSION:1.1 "cd $WORK_DIR && clear && pi $EXTENSIONS --name ${NAMES[1]} --model $THINKING_MODEL" Enter
  tmux send-keys -t $SESSION:1.2 "cd $WORK_DIR && clear && pi $EXTENSIONS --name ${NAMES[2]} --model $PLANNING_MODEL" Enter
  tmux send-keys -t $SESSION:1.3 "cd $WORK_DIR && clear && pi $EXTENSIONS --name ${NAMES[3]} --model $WORKER_MODEL" Enter
  tmux attach-session -t $SESSION
}

_pi_tmux_quote_args() {
  local -a quoted
  local arg

  for arg in "$@"; do
    quoted+=("${(q)arg}")
  done

  print -r -- "${(j: :)quoted}"
}

_pi4_command() {
  local work_dir="$1"
  local pane_number="$2"
  shift 2

  local -a args
  args=("$@")

  local pane_args_var="PI4_PANE_${pane_number}_ARGS"
  local pane_args_value="${(P)pane_args_var}"
  if [[ -n "$pane_args_value" ]]; then
    args+=(${(z)pane_args_value})
  fi

  local quoted_work_dir="$(_pi_tmux_quote_args "$work_dir")"
  local quoted_args="$(_pi_tmux_quote_args "${args[@]}")"
  local command="cd $quoted_work_dir && clear && pi"
  [[ -n "$quoted_args" ]] && command+=" $quoted_args"

  print -r -- "$command"
}

# Split the current tmux window into 4 panes and run pi in each pane.
# Uses the same args/env as pi4: function args, PI4_ARGS, and PI4_PANE_N_ARGS.
# Falls back to pi4 when called outside tmux.
pi4_here() {
  local work_dir="$PWD"
  local -a base_args

  if (( $# > 0 )); then
    base_args=("$@")
  elif [[ -n "$PI4_ARGS" ]]; then
    base_args=(${(z)PI4_ARGS})
  else
    base_args=()
  fi

  if [[ -z "$TMUX" ]]; then
    pi4 "${base_args[@]}"
    return
  fi

  local pane1 pane2 pane3 pane4 window
  pane1="$(tmux display-message -p '#{pane_id}')"
  window="$(tmux display-message -p '#{window_id}')"
  pane2="$(tmux split-window -h -P -F '#{pane_id}' -t "$pane1" -c "$work_dir")"
  pane3="$(tmux split-window -v -P -F '#{pane_id}' -t "$pane1" -c "$work_dir")"
  pane4="$(tmux split-window -v -P -F '#{pane_id}' -t "$pane2" -c "$work_dir")"
  tmux select-layout -t "$window" tiled >/dev/null

  local -a panes
  panes=("$pane1" "$pane2" "$pane3" "$pane4")

  local i command
  for i in {1..4}; do
    command="$(_pi4_command "$work_dir" "$i" "${base_args[@]}")"
    tmux send-keys -t "${panes[i]}" "$command" Enter
  done

  tmux select-pane -t "$pane1"
}

# Start a 4-pane tmux session in the current directory and run pi in each pane.
# Usage:
#   pi4 --model openai-codex/gpt-5.5:xhigh
#   PI4_ARGS="--provider github-copilot --model claude-haiku-4.5" pi4
#   PI4_PANE_1_ARGS="--name truus" PI4_PANE_2_ARGS="--name sjaak" pi4
# Env:
#   PI4_SESSION=<name>      override tmux session name (default: <cwd>-pi4)
#   PI4_ARGS=<args>         base pi args used when no function args are passed
#   PI4_PANE_N_ARGS=<args>  extra pi args for pane N (1-4)
#   PI4_REPLACE=1          kill and recreate an existing session with same name
pi4() {
  local work_dir="$PWD"
  local session="${PI4_SESSION:-$(basename "$work_dir")-pi4}"
  local -a base_args

  if (( $# > 0 )); then
    base_args=("$@")
  elif [[ -n "$PI4_ARGS" ]]; then
    base_args=(${(z)PI4_ARGS})
  else
    base_args=()
  fi

  if tmux has-session -t "$session" 2>/dev/null; then
    if [[ "$PI4_REPLACE" == "1" ]]; then
      tmux kill-session -t "$session"
    else
      tmux attach-session -t "$session"
      return
    fi
  fi

  tmux new-session -d -s "$session" -n pi -c "$work_dir"

  local pane1 pane2 pane3 pane4
  pane1="$(tmux display-message -p -t "$session:pi" '#{pane_id}')"
  pane2="$(tmux split-window -h -P -F '#{pane_id}' -t "$pane1" -c "$work_dir")"
  pane3="$(tmux split-window -v -P -F '#{pane_id}' -t "$pane1" -c "$work_dir")"
  pane4="$(tmux split-window -v -P -F '#{pane_id}' -t "$pane2" -c "$work_dir")"
  tmux select-layout -t "$session:pi" tiled >/dev/null

  local -a panes
  panes=("$pane1" "$pane2" "$pane3" "$pane4")

  local i command
  for i in {1..4}; do
    command="$(_pi4_command "$work_dir" "$i" "${base_args[@]}")"
    tmux send-keys -t "${panes[i]}" "$command" Enter
  done

  tmux select-pane -t "$pane1"
  tmux attach-session -t "$session"
}
