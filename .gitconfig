[core]
	hooksPath = ~/.config/git/hooks

[init]
    defaultBranch = main

[user]
	name = Leo van Haaren
	email = 814676+leovanhaaren@users.noreply.github.com
    signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIH8BGFzcwWi5fjHXzZhz0lADQDk2I4sG9d8/+SGj1tRD

[gpg]
    format = ssh

[commit]
    gpgsign = true

[pull]
    rebase = true

# Rewrite HTTPS GitHub URLs to use SSH
[url "git@github.com:"]
    insteadOf = https://github.com/

# Override for user and signing config for ksyos
[includeIf "hasconfig:remote.*.url:git@github.com-ksyos:Ksyos/**"]
    path = ~/.config/git/ksyos.gitconfig

[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
