{
  // Chat
  "chat.disableAIFeatures": true,
  //
  // Claude Code
  "claudeCode.preferredLocation": "sideBar",
  "claudeCode.selectedModel": "opus",
  //
  // Dev Containers
  "dev.containers.dockerPath": "podman",
  //
  // Dotfiles
  "dotfiles.installCommand": "~/dotfiles/installers/install-vscode.sh",
  "dotfiles.repository": "https://github.com/leovanhaaren/dotfiles.git",
  "dotfiles.targetPath": "~/dotfiles",
  //
  // Editor
  "editor.fastScrollSensitivity": 3,
  "editor.fontFamily": "'Fira Code'",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.fontWeight": "normal",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.guides.bracketPairs": true,
  "editor.inlineSuggest.enabled": true,
  "editor.lineNumbers": "relative",
  "editor.linkedEditing": true,
  "editor.minimap.enabled": false,
  "editor.suggest.insertMode": "replace",
  "editor.suggestSelection": "first",
  "editor.tabSize": 2,
  "editor.wordWrap": "off",
  //
  // Error Lens
  "errorLens.enabled": true,
  //
  // Explorer
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  //
  // Files
  "files.autoSave": "onWindowChange",
  //
  // Git
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.ignoreRebaseWarning": true,
  //
  // GitHub Copilot
  "github.copilot.enable": {
    "*": false,
    "plaintext": true,
    "markdown": true,
    "scminput": false,
    "svelte": true,
    "shellscript": false
  },
  "github.copilot.nextEditSuggestions.enabled": false,
  "github.copilot.selectedCompletionModel": "gpt-4o-copilot",
  //
  // GitHub Pull Requests
  "githubPullRequests.createOnPublishBranch": "never",
  //
  // JavaScript
  "javascript.format.enable": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  //
  // Language Overrides
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  //
  // Launch
  "launch": {},
  //
  // Terminal
  "terminal.external.osxExec": "iTerm.app",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.windows": "Ubuntu (WSL)",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.fontFamily": "'MesloLGS NF'",
  "terminal.integrated.fontSize": 12,
  "terminal.integrated.lineHeight": 1.1,
  //
  // TypeScript
  "typescript.format.enable": false,
  "typescript.updateImportsOnFileMove.enabled": "always",
  //
  // Update
  "update.showReleaseNotes": false,
  //
  // VS Icons
  "vsicons.dontShowNewVersionMessage": true,
  "vsicons.presets.jsOfficial": true,
  //
  // Window
  "window.zoomLevel": 0.5,
  //
  // Workbench
  "workbench.colorTheme": "MacOS Modern Dark - Ventura Xcode",
  "workbench.iconTheme": "catppuccin-macchiato",
  "workbench.preferredHighContrastColorTheme": "GitHub Dark Default",
  "workbench.productIconTheme": "macos-modern",
  "workbench.sideBar.location": "left",
  "workbench.startupEditor": "none",
  "workbench.statusBar.visible": true,
  //
  // Zen Mode
  "zenMode.centerLayout": false,
  "zenMode.fullScreen": true,
  "zenMode.hideLineNumbers": false,
  "zenMode.showTabs": "multiple",
  "zenMode.silentNotifications": true
}
