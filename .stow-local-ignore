# Files and dirs that should not be symlinked into ~

# Stow infrastructure
^\.git$
^\.gitignore$
^\.stow-local-ignore$

# Docs and repo metadata
^README\.md$
^LICENSE$
^CHANGELOG.*$
^CONTRIBUTING.*$

# macOS metadata
^\.DS_Store$

# Legacy duplicate config paths
# AeroSpace errors if both ~/.aerospace.toml and ~/.config/aerospace/aerospace.toml exist.
^\.aerospace\.toml$

# Editor artifacts
~$
\.swp$
\.swo$

# Setup / management scripts
^setup\.sh$
^uninstall\.sh$
^verify\.sh$
^Makefile$
^[Jj]ustfile$

# Non-config directories (handled by setup.sh or not meant for ~)
^install$
^scripts$
^homebrew$
^vscode$
^ssh$
^rtk$

# Repo-specific directories not meant for ~
^ai-providers$
^config$
^secrets$
^shell$
^\.worktrees$

# Brewfile symlinks (belong in repo, not ~)
^Brewfile$